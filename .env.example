# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Required by default for DiscoveryAgent and ProfilerAgent search (SerpAPI backend)
SERPAPI_API_KEY=...

# Optional for --search-backend perplexity (sonar-pro model)
PERPLEXITY_API_KEY=pplx-...

# Required: W&B API key for Weave tracing
WANDB_API_KEY=...

# Optional: GitHub token to avoid rate limits when fetching metadata
GITHUB_TOKEN=ghp_...

# Optional: W&B entity/project (defaults below)
WANDB_ENTITY=wandb-smle
WANDB_PROJECT=autoresearch-researcher
