# Required: OpenAI API key
OPENAI_API_KEY=sk-...
# Required by default for ResearcherAgent search (Serper backend)
SERPER_API_KEY=...
# Required only when using --search-backend perplexity
PERPLEXITY_API_KEY=...
# Optional: raises GitHub API rate limits
GITHUB_TOKEN=...
# Required: W&B API key for Weave tracing
WANDB_API_KEY=...
# Required: W&B entity/project for Weave traces and eval results
WANDB_ENTITY=<your-wandb-entity>
WANDB_PROJECT=discovery-forge